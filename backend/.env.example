# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=jansamadhan

# JWT Configuration
JWT_SECRET=your-very-secure-secret-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

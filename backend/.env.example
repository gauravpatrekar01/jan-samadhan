# Database Configuration
MONGODB_URI=mongodb://localhost:27017/jansamadhan

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Cloudinary Configuration (Media Upload)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AWS S3 Configuration (if using S3 as backup)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jansamadhan-uploads

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Application Configuration
DEBUG=false
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,pdf

# Analytics Configuration
ENABLE_PREDICTIVE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=365

# Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
SMS_API_KEY=your-sms-api-key

# Security Configuration
ENABLE_HTTPS_ONLY=true
SESSION_TIMEOUT_MINUTES=60
PASSWORD_MIN_LENGTH=8
